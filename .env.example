# gb-bot - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=
DAILY_ROOM_URL=  # Optional: leave empty to create a new room

# Gradient Bang
GB_ENV=prod
GB_API_BASE_LOCAL=http://127.0.0.1:54321/functions/v1
GB_API_BASE_PROD=https://api.gradient-bang.com/functions/v1
GB_EMAIL=
GB_PASSWORD=
GB_CHARACTER=HyperionBot


# Cartesia (STT/TTS)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID= # Optional: defaults to "71a7ad14-091c-4e8e-a314-022ece01c121" (British Reading Lady)

# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=


# OpenAI (STT/LLM/TTS/Realtime)
OPENAI_API_KEY=
OPENAI_MODEL= # Optional: defaults to "gpt-4.1"
