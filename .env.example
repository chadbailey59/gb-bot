# gb-bot - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=
DAILY_ROOM_URL=  # Optional: leave empty to create a new room

# Gradient Bang
GB_ENV=prod
GB_API_BASE_LOCAL=http://127.0.0.1:54321/functions/v1
GB_API_BASE_PROD=https://api.gradient-bang.com/functions/v1
GB_EMAIL=
GB_PASSWORD=

GB_CHARACTER=  # Optional: defaults to HyperionBot
GB_LOG_DAILY_JOIN_URL=false  # Local debugging only; true prints Daily room tokens in logs.


# Cartesia (STT/TTS)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=  # Optional: defaults to the built-in bot voice

# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=


# OpenAI (STT/LLM/TTS/Realtime)
OPENAI_API_KEY=
OPENAI_MODEL= # Optional: defaults to "gpt-4.1"
